{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:window:default",
    "shell:allow-open",
    "core:app:default",
    "dialog:allow-message",
    "dialog:default",
    "fs:allow-write-file",
    "fs:allow-create",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:default",
    "fs:allow-app-write"
  ]
}