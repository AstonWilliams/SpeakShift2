{
  "productName": "SpeakShift",
  "version": "0.2.1",
  "identifier": "com.speakShift.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "SpeakShift",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "databases": [
        {
          "name": "transcriptions",
          "driver": "sqlite",
          "url": "transcriptions.db"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/whisper/whisper-cli",
      "binaries/ffmpeg",
      "binaries/nllb-translation",
      "binaries/yt-dlp"
    ],
    "resources": [
      "binaries/onnx_runtime",
      "binaries/whisper"
    ]
  }
}
